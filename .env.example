# UpFlow API Keys & Secrets

# Anthropic Claude API
ANTHROPIC_API_KEY=your-claude-api-key-here

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Telegram Chat ID (where bot will send notifications)
TELEGRAM_CHAT_ID=your-chat-id-here

# Upwork API Credentials (GraphQL)
UPWORK_CLIENT_ID=your-upwork-client-id-here
UPWORK_CLIENT_SECRET=your-upwork-client-secret-here

# Database path (default is ./upflow.sqlite)
DATABASE_PATH=./upflow.sqlite
